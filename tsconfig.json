{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "paths": {
      "@contracts/*": ["./src/contracts/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
